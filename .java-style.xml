<profiles version="12">
    <profile kind="CodeFormatterProfile" name="CustomFormattingRules" version="12">

        <!-- Unlimited line width -->
        <setting id="org.eclipse.jdt.core.formatter.lineSplit" value="999999"/>

        <!-- Keep annotations on their own line -->
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_field" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_local_variable" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_member" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_method" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_before_annotation_on_field" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_before_annotation_on_member" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_before_annotation_on_method" value="insert"/>
        <setting id="org.eclipse.jdt.core.formatter.insert_new_line_after_annotation_on_parameter" value="insert"/>

    </profile>
</profiles>
